# Chatwoot instance
CHATWOOT_BASE_URL=https://support.commerceship.com
CHATWOOT_API_TOKEN=your-agent-or-bot-api-token
CHATWOOT_ACCOUNT_ID=1

# Help Center portal slug (Chatwoot Help Center > Portal > slug)
CHATWOOT_PORTAL_SLUG=commerceship-help

# Bot behavior
MATCH_THRESHOLD=0.3
COOLDOWN_SECONDS=30
PORT=3005

# Webhook security (from Chatwoot webhook config)
WEBHOOK_SECRET=

# Safety limits
MAX_MESSAGE_LENGTH=500
MAX_CONTACT_MESSAGES_PER_MINUTE=5
MAX_CONTACT_CONVERSATIONS_PER_HOUR=3
BOT_SENDER_ID=3
