# Chatwoot instance
CHATWOOT_BASE_URL=https://support.commerceship.com
CHATWOOT_API_TOKEN=your-agent-or-bot-api-token
CHATWOOT_ACCOUNT_ID=1

# Help Center portal slug (Chatwoot Help Center > Portal > slug)
CHATWOOT_PORTAL_SLUG=cs-parcel-help

# Bot behavior
MATCH_THRESHOLD=0.3
COOLDOWN_SECONDS=300
PORT=3005

# Optional: webhook secret for verifying Chatwoot webhook signatures
WEBHOOK_SECRET=
